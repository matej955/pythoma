{
  "expo": {
    "name": "Pythoma Sanctuary",
    "slug": "pythoma-sanctuary",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "com.pythoma.app",
    "backgroundColor": "#fffaf3",
    "splash": {
      "backgroundColor": "#20483a",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "pythoma",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.pythoma.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#20483a"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-web-browser",
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "eas": {
        "projectId": "f88ece27-60ea-4cc4-af0d-6cc1a90b2ccc"
      }
    }
  }
}
