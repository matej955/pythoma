rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function ownsRequestedUid() {
      return signedIn() && request.resource.data.uid == request.auth.uid;
    }

    match /appContent/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    match /communityMessages/{messageId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 4000;
      allow update, delete: if signedIn() && resource.data.uid == request.auth.uid;

      match /likes/{userId} {
        allow read: if true;
        allow create: if isSelf(userId) && ownsRequestedUid();
        allow delete: if isSelf(userId);
        allow update: if false;
      }
    }

    match /users/{userId} {
      allow read, write: if isSelf(userId);

      match /{document=**} {
        allow read, write: if isSelf(userId);
      }
    }

    match /userPrograms/{programId} {
      allow read: if signedIn()
        && (resource.data.uid == request.auth.uid || resource.data.email == request.auth.token.email);
      allow write: if false;
    }

    match /subscriptions/{subscriptionId} {
      allow read: if signedIn()
        && (resource.data.uid == request.auth.uid || resource.data.email == request.auth.token.email || subscriptionId == request.auth.uid);
      allow write: if false;
    }

    match /userSubscriptions/{subscriptionId} {
      allow read: if signedIn()
        && (resource.data.uid == request.auth.uid || resource.data.email == request.auth.token.email || subscriptionId == request.auth.uid);
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
